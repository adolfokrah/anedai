# Claude Agent SDK — the coding agent
ANTHROPIC_API_KEY=

# E2B — cloud sandbox runtime (clone/scaffold, install, run dev server)
E2B_API_KEY=

# GitHub — per-user OAuth (recommended). Register an OAuth App:
# https://github.com/settings/applications/new (callback: <origin>/api/auth/github/callback)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Override the callback (e.g. an ngrok https URL); defaults to the request origin.
GITHUB_OAUTH_CALLBACK=
# Signs the session cookie — any long random string.
AUTH_SECRET=

# Fallback PAT (`repo` scope) used when no user is connected — optional, for local/dev.
GITHUB_TOKEN=
